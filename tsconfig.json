{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@anvil-dev/cli": ["./packages/cli/src"],
      "@anvil-dev/dashboard": ["./packages/dashboard/src"]
    }
  },
  "references": [
    { "path": "packages/cli" },
    { "path": "packages/dashboard" }
  ]
}
