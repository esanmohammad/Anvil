{
  "name": "@esankhan3/anvil-cli",
  "version": "0.0.3",
  "description": "Anvil — AI-powered feature development pipeline (CLI + dashboard)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/esanmohammad/Anvil#readme",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "keywords": [
    "anvil",
    "cli",
    "dashboard",
    "ai",
    "agent",
    "code-generation",
    "devtools",
    "pipeline"
  ],
  "bin": {
    "anvil": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./knowledge/*": "./dist/knowledge/*.js",
    "./pipeline/*": "./dist/pipeline/*.js",
    "./learn/*": "./dist/learn/*.js",
    "./conventions/*": "./dist/conventions/*.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm --prefix ../dashboard run build && tsc -b && node ./scripts/bundle-dashboard.mjs && cp src/templates/*.yaml dist/templates/ 2>/dev/null; mkdir -p dist/personas/prompts && cp src/personas/prompts/*.md dist/personas/prompts/ 2>/dev/null; true",
    "dev": "tsc -b --watch",
    "test": "echo 'cli has no per-workspace node:test files (knowledge tests moved to @anvil/knowledge-core; hooks integration test runs via root jest)'"
  },
  "dependencies": {
    "@anvil/agent-core": "*",
    "@anvil/core-pipeline": "*",
    "@anvil/knowledge-core": "*",
    "@anvil/memory-core": "*",
    "commander": "^13.1.0",
    "lucide-react": "1.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-2d": "1.29.1",
    "ws": "^8.18.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2"
  }
}
