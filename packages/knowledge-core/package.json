{
  "name": "@esankhan3/anvil-knowledge-core",
  "version": "0.3.7",
  "description": "Shared knowledge stack (chunking, AST, embedders, vector store, hybrid retrieval) for cli + code-search-mcp.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "tsc -b && node --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "@esankhan3/anvil-agent-core": "^0.4.0",
    "@lancedb/lancedb": "0.27.2",
    "apache-arrow": "17.0.0",
    "graphology": "0.26.0",
    "graphology-communities-louvain": "2.0.2",
    "graphology-metrics": "2.4.0",
    "graphology-types": "0.24.8",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.26.8"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/knowledge-core"
  },
  "homepage": "https://github.com/esanmohammad/Anvil/tree/main/packages/knowledge-core#readme",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
