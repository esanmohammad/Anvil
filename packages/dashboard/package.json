{
  "name": "@anvil-dev/dashboard",
  "version": "0.3.0",
  "private": true,
  "description": "React dashboard and Node.js server for Anvil — real-time pipeline orchestration, knowledge graph visualization, and agent management",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/dashboard"
  },
  "homepage": "https://github.com/esanmohammad/Anvil#dashboard",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "keywords": [
    "anvil",
    "dashboard",
    "react",
    "pipeline",
    "ai",
    "agents",
    "knowledge-graph"
  ],
  "main": "./server/dashboard-server.js",
  "exports": {
    ".": "./server/dashboard-server.js",
    "./server/*": "./server/*.js"
  },
  "files": [
    "dist",
    "server/**/*.js",
    "server/**/*.d.ts",
    "!server/out/**",
    "!server/__tests__/**",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p server/tsconfig.json && node ./scripts/copy-out.mjs",
    "preview": "vite preview",
    "test:server": "npx tsc -p server/tsconfig.json && node --test server/out/__tests__/*.test.js"
  },
  "dependencies": {
    "@esankhan3/anvil-agent-core": "^0.3.0",
    "@esankhan3/anvil-convention-core": "^0.3.0",
    "@esankhan3/anvil-core-pipeline": "^0.3.0",
    "@esankhan3/anvil-knowledge-core": "^0.3.0",
    "@esankhan3/anvil-memory-core": "^0.3.0",
    "@huggingface/transformers": "^4.2.0",
    "lucide-react": "1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-2d": "1.29.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ts-pattern": "^5.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.2"
  }
}
