{
  "name": "@anvil-dev/dashboard",
  "version": "0.1.0",
  "description": "React dashboard and Node.js server for Anvil — real-time pipeline orchestration, knowledge graph visualization, and agent management",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/dashboard"
  },
  "homepage": "https://github.com/esanmohammad/Anvil#dashboard",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "keywords": ["anvil", "dashboard", "react", "pipeline", "ai", "agents", "knowledge-graph"],
  "main": "./server/dashboard-server.js",
  "exports": {
    ".": "./server/dashboard-server.js",
    "./server/*": "./server/*.js"
  },
  "files": [
    "dist",
    "server/*.js",
    "server/*.d.ts",
    "server/adapters/*.js",
    "server/adapters/*.d.ts",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p server/tsconfig.json && cp server/out/*.js server/out/*.d.ts server/ 2>/dev/null; cp server/out/adapters/*.js server/out/adapters/*.d.ts server/adapters/ 2>/dev/null; true",
    "preview": "vite preview",
    "test:server": "npx tsc -p server/tsconfig.json && node --test server/out/__tests__/*.test.js"
  },
  "dependencies": {
    "lucide-react": "1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-2d": "1.29.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "vite": "^6.3.2"
  }
}
