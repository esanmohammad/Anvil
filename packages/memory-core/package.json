{
  "name": "@esankhan3/anvil-memory-core",
  "version": "0.3.0",
  "description": "Long-term memory layer for Anvil — five-type taxonomy (working/episodic/semantic/procedural/profile), bi-temporal facts, code-fact drift detection, sleeptime ratification, PR-as-episode primitives.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "tsc -b && node --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "@esankhan3/anvil-agent-core": "^0.3.0",
    "@esankhan3/anvil-knowledge-core": "^0.3.0",
    "better-sqlite3": "^11.7.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.15.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/memory-core"
  },
  "homepage": "https://github.com/esanmohammad/Anvil/tree/main/packages/memory-core#readme",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
