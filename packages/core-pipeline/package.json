{
  "name": "@esankhan3/anvil-core-pipeline",
  "version": "0.3.0",
  "description": "Core pipeline runner for Anvil — typed Step<I,O> graph, EventBus, StepRegistry, lifecycle hooks. Replaces cli's monolithic orchestrator if-tree.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && mkdir -p dist/routing && cp src/routing/*.yaml dist/routing/ 2>/dev/null; true",
    "dev": "tsc -b --watch",
    "test": "tsc -b && mkdir -p dist/routing && cp src/routing/*.yaml dist/routing/ 2>/dev/null; node --test dist/__tests__/*.test.js",
    "lint:stages": "tsc -b && node scripts/lint-stages.js"
  },
  "dependencies": {
    "@esankhan3/anvil-agent-core": "^0.3.0",
    "@esankhan3/anvil-memory-core": "^0.3.0",
    "better-sqlite3": "^11.7.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.15.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/core-pipeline"
  },
  "homepage": "https://github.com/esanmohammad/Anvil/tree/main/packages/core-pipeline#readme",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
