{
  "name": "@esankhan3/anvil-convention-core",
  "version": "0.3.0",
  "description": "Project convention extraction, rule engine, and promotion ledger for Anvil. Owns ~/.anvil/conventions/<project>/{conventions.md, rules.json}.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "tsc -b && node --test dist/__tests__/*.test.js"
  },
  "dependencies": {
    "@esankhan3/anvil-memory-core": "^0.3.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/esanmohammad/Anvil.git",
    "directory": "packages/convention-core"
  },
  "homepage": "https://github.com/esanmohammad/Anvil/tree/main/packages/convention-core#readme",
  "bugs": {
    "url": "https://github.com/esanmohammad/Anvil/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
