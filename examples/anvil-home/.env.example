# ──────────────────────────────────────────────────────────────────────
# ~/.anvil/.env — provider keys + observability
#
# Copy this to ~/.anvil/.env (chmod 600) and fill in the providers
# you actually use. The dashboard loads this file on startup and
# only honors a known allowlist of keys — no env injection.
# ──────────────────────────────────────────────────────────────────────

# ─── Provider keys ────────────────────────────────────────────────────
# Set whichever providers you have credentials for. Anvil auto-detects
# what's available; missing providers are silently skipped.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...                        # also covers Gemini + ADK
# GEMINI_API_KEY=...                      # alternative name; either works
OPENROUTER_API_KEY=sk-or-...
OPENCODE_API_KEY=...                      # opencode.ai/zen Go subscription
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1   # default

# Ollama is auto-detected on localhost:11434 — uncomment to override.
# OLLAMA_HOST=http://localhost:11434

# ─── GitHub ───────────────────────────────────────────────────────────
# Used by the ship stage for `gh pr create` and by knowledge-core's
# GitHub-org clone path.
GITHUB_TOKEN=ghp_...

# ─── Observability (opt-in) ───────────────────────────────────────────
# Telemetry is OFF by default. Uncomment one of the two switches below
# to turn it on.

# 1. Export to an OTLP collector (Langfuse, Tempo, Honeycomb, …)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel/v1/traces
# OTEL_SERVICE_NAME=anvil-dashboard
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer pk-...

# 2. Dump spans to stderr (useful for debugging without a collector)
# ANVIL_OTEL_CONSOLE=1

# Privacy — by default, prompt + completion text are NOT recorded in
# spans. Set to 1 to include them (truncated to 8 KB per attribute).
# ANVIL_OTEL_RECORD_CONTENT=1

# Hard kill-switch
# ANVIL_OTEL_DISABLED=1
